{
    "hosting": {
        "site": "agasa-core-5c10d",
        "public": "public",
        "cleanUrls": true,
        "trailingSlash": false,
        "rewrites": [
            {
                "source": "**",
                "run": {
                    "serviceId": "agasa-core",
                    "region": "europe-west1"
                }
            }
        ],
        "headers": [
            {
                "source": "**",
                "headers": [
                    {
                        "key": "X-Frame-Options",
                        "value": "DENY"
                    },
                    {
                        "key": "X-Content-Type-Options",
                        "value": "nosniff"
                    },
                    {
                        "key": "Referrer-Policy",
                        "value": "strict-origin-when-cross-origin"
                    }
                ]
            }
        ]
    }
}